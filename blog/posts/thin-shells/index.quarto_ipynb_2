    "---\n",
    "title: \"Thin shells and misleading projections\"\n",
    "date: 2026-04-18\n",
    "description: \"A note on why high-dimensional structure can disappear in 2D.\"\n",
    "categories: [notes]\n",
    "jupyter: python3\n",
    "execute:\n",
    "  echo: false\n",
    "  warning: false\n",
