    "#| label: setup\n",
    "# The code below defines the helper functions used in all figures.\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "rng = np.random.default_rng(7)\n",
    "\n",
    "plt.rcParams[\"figure.dpi\"] = 110\n",
    "plt.rcParams[\"axes.titlesize\"] = 10\n",
    "plt.rcParams[\"axes.labelsize\"] = 9\n",
    "\n",
    "dims = [2, 5, 20, 50, 200]\n",
    "n_gaussian = 1500\n",
    "n_mixture = 2200\n",
    "delta = 4.0\n",
    "\n",
    "\n",
    "def random_orthonormal_pair(d, rng):\n",
    "    G = rng.normal(size=(d, 2))\n",
    "    Q, _ = np.linalg.qr(G)\n",
    "    return Q[:, :2]\n",
    "\n",
    "\n",
    "def random_unit_vector(d, rng):\n",
    "    v = rng.normal(size=d)\n",
    "    return v / np.linalg.norm(v)\n",
    "\n",
    "\n",
    "def shell_proxy(X, scale=True, rng=None):\n",
    "    if rng is None:\n",
    "        rng = np.random.default_rng()\n",
    "    r = np.linalg.norm(X, axis=1)\n",
    "    if scale:\n",
    "        r = r / np.sqrt(X.shape[1])\n",
    "    theta = rng.uniform(0.0, 2.0 * np.pi, size=len(r))\n",
    "    return np.column_stack([r * np.cos(theta), r * np.sin(theta)])\n",
    "\n",
    "\n",
    "def random_projection(X, rng):\n",
    "    U = random_orthonormal_pair(X.shape[1], rng)\n",
    "    return X @ U, U\n",
    "\n",
    "\n",
    "def pca_projection(X):\n",
    "    Xc = X - X.mean(axis=0, keepdims=True)\n",
    "    _, S, Vt = np.linalg.svd(Xc, full_matrices=False)\n",
    "    scores = Xc @ Vt[:2].T\n",
    "    eigvals = (S[:2] ** 2) / (X.shape[0] - 1)\n",
    "    return scores, eigvals, Vt[:2]\n",
    "\n",
    "\n",
    "def style_equal_panel(ax, lim=None):\n",
    "    if lim is not None:\n",
    "        ax.set_xlim(-lim, lim)\n",
    "        ax.set_ylim(-lim, lim)\n",
    "    ax.set_xticks([])\n",
    "    ax.set_yticks([])\n",
    "    ax.set_aspect(\"equal\", adjustable=\"box\")\n",
    "    ax.grid(False)\n",
    "\n",
    "\n",
    "def panel_limits(Y, pad_ratio=0.08):\n",
    "    xmin, ymin = Y.min(axis=0)\n",
    "    xmax, ymax = Y.max(axis=0)\n",
    "    xr = max(xmax - xmin, 1.0)\n",
    "    yr = max(ymax - ymin, 1.0)\n",
    "    return (\n",
    "        xmin - pad_ratio * xr,\n",
    "        xmax + pad_ratio * xr,\n",
    "        ymin - pad_ratio * yr,\n",
    "        ymax + pad_ratio * yr,\n",
    "    )\n",
    "\n",
    "\n",
    "def sample_bimodal_gaussian(d, n=2200, delta=4.0, rng=None):\n",
    "    if rng is None:\n",
    "        rng = np.random.default_rng()\n",
    "    labels = rng.integers(0, 2, size=n)\n",
    "    signs = 2 * labels - 1\n",
    "    X = rng.normal(size=(n, d))\n",
    "    X[:, 0] += delta * signs\n",
    "    return X, labels\n",
    "\n",
    "\n",
    "def gaussian_shell_vs_projection_figure(dims_subset, n=1500, rng=None):\n",
    "    if rng is None:\n",
    "        rng = np.random.default_rng()\n",
    "\n",
    "    fig, axes = plt.subplots(\n",
    "        2, len(dims_subset),\n",
    "        figsize=(2.1 * len(dims_subset), 3.5),\n",
    "        constrained_layout=True\n",
    "    )\n",
    "\n",
    "    if len(dims_subset) == 1:\n",
    "        axes = np.array(axes).reshape(2, 1)\n",
    "\n",
    "    for col, d in enumerate(dims_subset):\n",
    "        X = rng.normal(size=(n, d))\n",
    "\n",
    "        ax = axes[0, col]\n",
    "        S = shell_proxy(X, scale=True, rng=rng)\n",
    "        ax.scatter(S[:, 0], S[:, 1], s=5, alpha=0.22)\n",
    "        circle = plt.Circle((0, 0), 1.0, fill=False, ls=\"--\", lw=1.0, alpha=0.7)\n",
    "        ax.add_patch(circle)\n",
    "        style_equal_panel(ax, lim=1.55)\n",
    "        ax.set_title(rf\"$d={d}$\")\n",
    "        if col == 0:\n",
    "            ax.set_ylabel(\"shell\")\n",
    "\n",
    "        ax = axes[1, col]\n",
    "        P, _ = random_projection(X, rng)\n",
    "        ax.scatter(P[:, 0], P[:, 1], s=5, alpha=0.22)\n",
    "        style_equal_panel(ax, lim=4.2)\n",
    "        if col == 0:\n",
    "            ax.set_ylabel(\"random 2D\")\n",
    "\n",
    "    return fig\n",
    "\n",
    "\n",
    "def mixture_views_figure(dims_subset, n=2200, delta=4.0, rng=None):\n",
    "    if rng is None:\n",
    "        rng = np.random.default_rng()\n",
    "\n",
    "    fig, axes = plt.subplots(\n",
    "        3, len(dims_subset),\n",
    "        figsize=(2.1 * len(dims_subset), 5.2),\n",
    "        constrained_layout=True\n",
    "    )\n",
    "\n",
    "    if len(dims_subset) == 1:\n",
    "        axes = np.array(axes).reshape(3, 1)\n",
    "\n",
    "    for col, d in enumerate(dims_subset):\n",
    "        X, labels = sample_bimodal_gaussian(d=d, n=n, delta=delta, rng=rng)\n",
    "        mask0 = labels == 0\n",
    "        mask1 = ~mask0\n",
    "\n",
    "        ax = axes[0, col]\n",
    "        if d == 2:\n",
    "            Y1 = X[:, :2]\n",
    "            title = rf\"$d={d}$\" + \"\\ncloud\"\n",
    "        else:\n",
    "            Y1 = shell_proxy(X, scale=False, rng=rng)\n",
    "            title = rf\"$d={d}$\" + \"\\nshell proxy\"\n",
    "\n",
    "        ax.scatter(Y1[mask0, 0], Y1[mask0, 1], s=3.5, alpha=0.24)\n",
    "        ax.scatter(Y1[mask1, 0], Y1[mask1, 1], s=3.5, alpha=0.24)\n",
    "        x0, x1, y0, y1 = panel_limits(Y1)\n",
    "        ax.set_xlim(x0, x1)\n",
    "        ax.set_ylim(y0, y1)\n",
    "        ax.set_xticks([])\n",
    "        ax.set_yticks([])\n",
    "        ax.set_aspect(\"equal\")\n",
    "        ax.set_title(title, fontsize=9)\n",
    "        if col == 0:\n",
    "            ax.set_ylabel(\"shell proxy\")\n",
    "\n",
    "        ax = axes[1, col]\n",
    "        Yr, U = random_projection(X, rng)\n",
    "        ax.scatter(Yr[mask0, 0], Yr[mask0, 1], s=3.5, alpha=0.24)\n",
    "        ax.scatter(Yr[mask1, 0], Yr[mask1, 1], s=3.5, alpha=0.24)\n",
    "        x0, x1, y0, y1 = panel_limits(Yr)\n",
    "        ax.set_xlim(x0, x1)\n",
    "        ax.set_ylim(y0, y1)\n",
    "        ax.set_xticks([])\n",
    "        ax.set_yticks([])\n",
    "        ax.set_aspect(\"equal\")\n",
    "        vis = delta * np.linalg.norm(U[0, :])\n",
    "        ax.text(\n",
    "            0.03, 0.97, f\"projected separation = {vis:.2f}\",\n",
    "            transform=ax.transAxes, va=\"top\", fontsize=7.5,\n",
    "            bbox=dict(boxstyle=\"round,pad=0.16\", alpha=0.10),\n",
    "        )\n",
    "        if col == 0:\n",
    "            ax.set_ylabel(\"random 2D\")\n",
    "\n",
    "        ax = axes[2, col]\n",
    "        Yp, eigvals, pcs = pca_projection(X)\n",
    "        ax.scatter(Yp[mask0, 0], Yp[mask0, 1], s=3.5, alpha=0.24)\n",
    "        ax.scatter(Yp[mask1, 0], Yp[mask1, 1], s=3.5, alpha=0.24)\n",
    "        x0, x1, y0, y1 = panel_limits(Yp)\n",
    "        ax.set_xlim(x0, x1)\n",
    "        ax.set_ylim(y0, y1)\n",
    "        ax.set_xticks([])\n",
    "        ax.set_yticks([])\n",
    "        ax.set_aspect(\"equal\")\n",
    "        ax.text(\n",
    "            0.03, 0.97, rf\"$\\lambda_1$ = {eigvals[0]:.2f}\",\n",
    "            transform=ax.transAxes, va=\"top\", fontsize=7.5,\n",
    "            bbox=dict(boxstyle=\"round,pad=0.16\", alpha=0.10),\n",
    "        )\n",
    "        if col == 0:\n",
    "            ax.set_ylabel(\"PCA\")\n",
    "\n",
    "    return fig"
   ]
